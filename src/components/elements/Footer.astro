---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
---

<div class="mt-16"></div>
<footer class="relative bg-box-bg pt-16 pb-8 border-t border-box-border">
    <Container className="relative z-10">
        <div class="flex flex-col items-center text-center max-w-4xl mx-auto">
            
            <div class="mb-8 flex items-center justify-center">
                <a href="/">
                    <img src="/logo.png" alt="Nas Hub" class="h-10 w-auto" />
                </a>
            </div>

            <Paragraph className="text-sm md:text-base mb-6">
                Nas Hub is a service of <span class="font-bold text-heading-2">Nasir Digital Consultancy Limited</span>.<br/>A private limited company registered in England and Wales.
            </Paragraph>

            <div class="flex flex-col sm:flex-row flex-wrap justify-center items-center gap-x-6 gap-y-3 mb-8 text-sm font-medium text-heading-3">
                <a href="#" class="hover:text-orange-500 transition-colors">Privacy Policy</a>
                <span class="text-box-border hidden sm:inline">•</span>
                <a href="#" class="hover:text-orange-500 transition-colors">Terms & Conditions</a>
                <span class="text-box-border hidden sm:inline">•</span>
                <a href="mailto:hello@nashub.uk" class="hover:text-orange-500 transition-colors">Contact Us</a>
            </div>

            <div class="flex flex-col sm:flex-row flex-wrap justify-center items-center gap-x-6 gap-y-4 mb-8 text-sm text-heading-3">
                <a href="mailto:hello@nashub.uk" class="hover:text-orange-500 transition-colors flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                    hello@nashub.uk
                </a>
                <a href="https://wa.me/447449728800" target="_blank" rel="noopener noreferrer" class="hover:text-green-500 transition-colors flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                    WhatsApp Us
                </a>
                <a href="https://nashub.uk" class="hover:text-orange-500 transition-colors flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.974 0-5.76.118-8.313.317m15.686 0a8.959 8.959 0 01-1.25 5.22m-13.186 0a8.959 8.959 0 01-1.25-5.22m15.686 0A11.953 11.953 0 0112 10.5c-2.974 0-5.76.118-8.313.317m15.686 0a8.959 8.959 0 01-1.25 5.22m-13.186 0a8.959 8.959 0 01-1.25-5.22" />
                    </svg>
                    nashub.uk
                </a>
            </div>

            <div class="w-full h-px bg-gradient-to-r from-transparent via-box-border to-transparent mb-8"></div>
            
            <div class="text-sm text-heading-3">
                Part of <a href="http://ndc-agency.co.uk" target="_blank" rel="noopener noreferrer" class="font-bold hover:text-orange-500 transition-colors">ndc-agency.co.uk</a>
            </div>
            <div class="mt-4 text-xs text-heading-3/70">
                &copy; <span id="year"></span> Nas Hub. All rights reserved.
            </div>
            <div class="mt-2 text-xs text-heading-3/60">
                Crafted by <a href="https://prodo.top" target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors">Prodo</a>
            </div>

        </div>
    </Container>
    
    <!-- Script for current year -->
    <script>
        const yearElement = document.getElementById("year");
        if(yearElement) {
            yearElement.textContent = new Date().getFullYear().toString();
        }
    </script>
</footer>
