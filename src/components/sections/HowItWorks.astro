---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";
---

<section id="how-it-works" class="relative pt-20 pb-20">
    <Container className="relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-heading-1">
                How it works: <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-500">3 simple steps</span>
            </h2>
            <Paragraph className="mt-4">
                We've made it as simple as possible to get your professional portfolio online.
            </Paragraph>
        </div>

        <div class="grid md:grid-cols-3 gap-8 lg:gap-12 relative">
            <!-- Connecting Line for Desktop -->
            <div class="hidden md:block absolute top-1/2 left-[10%] right-[10%] h-0.5 bg-gradient-to-r from-orange-500/0 via-orange-500/30 to-red-500/0 -translate-y-1/2 z-0"></div>

            <!-- Step 1 -->
            <div class="relative z-10 group">
                <div class="bg-box-bg/80 backdrop-blur-xl border border-box-border p-8 rounded-3xl shadow-lg hover:shadow-xl hover:-translate-y-2 transition-all duration-300 h-full flex flex-col items-center text-center">
                    <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-orange-600 rounded-2xl flex items-center justify-center text-white font-bold text-2xl mb-6 shadow-lg shadow-orange-500/30 group-hover:scale-110 transition-transform duration-300 rotate-3 group-hover:-rotate-3">
                        1
                    </div>
                    <h3 class="text-xl font-bold text-heading-2 mb-4">Fill in your details</h3>
                    <Paragraph className="text-sm md:text-base">
                        Complete our simple online form with your name, skills, experience, photo, and links. Takes about 10 minutes.
                    </Paragraph>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="relative z-10 group">
                <div class="bg-box-bg/80 backdrop-blur-xl border border-box-border p-8 rounded-3xl shadow-lg hover:shadow-xl hover:-translate-y-2 transition-all duration-300 h-full flex flex-col items-center text-center">
                    <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-pink-500 rounded-2xl flex items-center justify-center text-white font-bold text-2xl mb-6 shadow-lg shadow-orange-500/30 group-hover:scale-110 transition-transform duration-300 -rotate-3 group-hover:rotate-3">
                        2
                    </div>
                    <h3 class="text-xl font-bold text-heading-2 mb-4">We build your portfolio</h3>
                    <Paragraph className="text-sm md:text-base">
                        Our developer builds your professional portfolio by hand. Clean, personalised, and ready within 2–3 working days.
                    </Paragraph>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="relative z-10 group">
                <div class="bg-box-bg/80 backdrop-blur-xl border border-box-border p-8 rounded-3xl shadow-lg hover:shadow-xl hover:-translate-y-2 transition-all duration-300 h-full flex flex-col items-center text-center">
                    <div class="w-16 h-16 bg-gradient-to-br from-red-500 to-amber-500 rounded-2xl flex items-center justify-center text-white font-bold text-2xl mb-6 shadow-lg shadow-red-500/30 group-hover:scale-110 transition-transform duration-300 rotate-3 group-hover:-rotate-3">
                        3
                    </div>
                    <h3 class="text-xl font-bold text-heading-2 mb-4">Go live instantly</h3>
                    <Paragraph className="text-sm md:text-base">
                        Your portfolio goes live at <span class="font-semibold text-orange-400">yourname.nashub.uk</span>. Share it on LinkedIn, your CV, and job applications straight away.
                    </Paragraph>
                </div>
            </div>
        </div>
    </Container>
</section>
