---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
---

<section class="relative pt-24 pb-24">
    <Container>
        <div class="relative bg-gradient-to-r from-orange-600 to-red-600 rounded-3xl p-10 md:p-16 overflow-hidden shadow-2xl">
            
            <!-- Background Decorations -->
            <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-64 h-64 bg-orange-500 rounded-full blur-3xl opacity-50"></div>
            <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-64 h-64 bg-orange-500 rounded-full blur-3xl opacity-50"></div>
            
            <div class="relative z-10 flex flex-col items-center text-center max-w-2xl mx-auto">
                <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
                    Ready to go live?
                </h2>
                
                <Paragraph className="text-orange-100 text-lg md:text-xl mb-10">
                    Join hundreds of people who already have their own professional portfolio online. It takes 10 minutes to get started.
                </Paragraph>
                
                <div class="flex flex-col items-center w-full">
                    <a href="https://app.nashub.uk" target="_blank" rel="noopener noreferrer">
                        <button class="w-full sm:w-auto px-10 py-5 rounded-full bg-white text-orange-900 font-bold text-lg hover:bg-orange-50 transition-colors duration-300 shadow-xl shadow-black/20 hover:-translate-y-1">
                            Get My Portfolio for £10
                        </button>
                    </a>
                    
                    <p class="mt-4 text-sm text-orange-200">
                        No tech skills needed. Live in 2–3 working days.
                    </p>
                </div>
            </div>
        </div>
    </Container>
</section>
