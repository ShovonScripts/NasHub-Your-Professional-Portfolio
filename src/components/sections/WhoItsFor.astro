---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
---

<section id="who-its-for" class="relative pt-20 pb-20">
    <Container>
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-heading-1">
                Built for anyone who wants to <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-orange-500">stand out online</span>
            </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            
            <!-- Students & Graduates -->
            <div class="group bg-box-bg border border-box-border p-6 rounded-2xl hover:bg-gradient-to-br hover:from-orange-600 hover:to-orange-700 transition-all duration-500 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500 group-hover:scale-110 transform">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-24 h-24 text-white">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                    </svg>
                </div>
                <div class="relative z-10">
                    <h3 class="text-xl font-bold text-heading-2 group-hover:text-white mb-3 transition-colors duration-300">Students & Graduates</h3>
                    <Paragraph className="group-hover:text-white/80 transition-colors duration-300 text-sm">
                        Show employers your projects, skills, and personality before you even walk in the door.
                    </Paragraph>
                </div>
            </div>

            <!-- Job Seekers -->
            <div class="group bg-box-bg border border-box-border p-6 rounded-2xl hover:bg-gradient-to-br hover:from-red-600 hover:to-orange-700 transition-all duration-500 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500 group-hover:scale-110 transform">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-24 h-24 text-white">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
                    </svg>
                </div>
                <div class="relative z-10">
                    <h3 class="text-xl font-bold text-heading-2 group-hover:text-white mb-3 transition-colors duration-300">Job Seekers</h3>
                    <Paragraph className="group-hover:text-white/80 transition-colors duration-300 text-sm">
                        Stand out from hundreds of CVs with a live portfolio link that speaks for itself.
                    </Paragraph>
                </div>
            </div>

            <!-- Freelancers & Creatives -->
            <div class="group bg-box-bg border border-box-border p-6 rounded-2xl hover:bg-gradient-to-br hover:from-orange-600 hover:to-pink-600 transition-all duration-500 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500 group-hover:scale-110 transform">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-24 h-24 text-white">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.879-5.818a1.5 1.5 0 00-2.112-2.13l-5.818 3.88a15.994 15.994 0 00-4.648 4.764m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
                    </svg>
                </div>
                <div class="relative z-10">
                    <h3 class="text-xl font-bold text-heading-2 group-hover:text-white mb-3 transition-colors duration-300">Freelancers & Creatives</h3>
                    <Paragraph className="group-hover:text-white/80 transition-colors duration-300 text-sm">
                        Show your work, your style, and your contact details. All in one professional place.
                    </Paragraph>
                </div>
            </div>

            <!-- Professionals -->
            <div class="group bg-box-bg border border-box-border p-6 rounded-2xl hover:bg-gradient-to-br hover:from-amber-600 hover:to-red-600 transition-all duration-500 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity duration-500 group-hover:scale-110 transform">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-24 h-24 text-white">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                    </svg>
                </div>
                <div class="relative z-10">
                    <h3 class="text-xl font-bold text-heading-2 group-hover:text-white mb-3 transition-colors duration-300">Professionals</h3>
                    <Paragraph className="group-hover:text-white/80 transition-colors duration-300 text-sm">
                        Build your personal brand and make a strong first impression when people search for you online.
                    </Paragraph>
                </div>
            </div>

        </div>
    </Container>
</section>
