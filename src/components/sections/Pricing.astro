---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
---

<section id="pricing" class="relative pt-20 pb-20 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl aspect-video bg-gradient-to-tr from-orange-500/10 to-orange-500/10 blur-[100px] rounded-full z-0 pointer-events-none"></div>

    <Container className="relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-heading-1">
                Simple, <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-500">honest pricing</span>
            </h2>
            <Paragraph className="mt-4">
                Here is exactly what you pay and when. No surprises, no contracts.
            </Paragraph>
        </div>

        <!-- Step-by-step pricing journey -->
        <div class="max-w-4xl mx-auto">

            <!-- Connector line (desktop) -->
            <div class="relative">

                <!-- Step 1 -->
                <div class="flex flex-col md:flex-row items-stretch gap-0 mb-0 group">
                    <div class="flex flex-col items-center md:items-start md:w-16 shrink-0">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-orange-500/30 z-10 shrink-0">
                            1
                        </div>
                        <!-- Vertical connector -->
                        <div class="w-0.5 flex-1 bg-gradient-to-b from-orange-500/50 to-orange-500/30 mt-2 hidden md:block min-h-[60px]"></div>
                    </div>

                    <div class="md:ml-6 mb-4 md:mb-0 flex-1 pb-8">
                        <div class="bg-box-bg border border-box-border rounded-2xl p-6 md:p-8 flex flex-col sm:flex-row sm:items-center gap-6 hover:border-orange-500/40 transition-colors duration-300">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-2">
                                    <span class="text-xs font-bold uppercase tracking-widest text-orange-400 bg-orange-500/10 px-3 py-1 rounded-full">One-time</span>
                                </div>
                                <h3 class="text-xl font-bold text-heading-1 mb-2">Get started</h3>
                                <p class="text-heading-3 text-sm leading-relaxed">
                                    Pay once to get your portfolio built and live. Includes your <span class="font-medium text-heading-2">first month of hosting</span> at no extra cost. Ready within 2–3 working days.
                                </p>
                                <ul class="mt-4 space-y-1.5 text-sm text-heading-3">
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Portfolio built by hand</li>
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Live at yourname.nashub.uk</li>
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>First month hosting included</li>
                                </ul>
                            </div>
                            <div class="text-center sm:text-right shrink-0">
                                <div class="text-5xl font-bold text-heading-1">£10</div>
                                <div class="text-sm text-heading-3 mt-1">one-time payment</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="flex flex-col md:flex-row items-stretch gap-0 mb-0 group">
                    <div class="flex flex-col items-center md:items-start md:w-16 shrink-0">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-orange-500/30 z-10 shrink-0">
                            2
                        </div>
                        <!-- Vertical connector -->
                        <div class="w-0.5 flex-1 bg-gradient-to-b from-orange-500/30 to-red-500/20 mt-2 hidden md:block min-h-[60px]"></div>
                    </div>

                    <div class="md:ml-6 mb-4 md:mb-0 flex-1 pb-8">
                        <div class="bg-gradient-to-r from-orange-500/5 to-orange-500/5 border border-orange-500/30 rounded-2xl p-6 md:p-8 flex flex-col sm:flex-row sm:items-center gap-6 relative overflow-hidden">
                            <div class="absolute top-3 right-4 text-xs font-bold uppercase tracking-widest text-white bg-gradient-to-r from-orange-600 to-orange-600 px-3 py-1 rounded-full shadow">
                                Ongoing
                            </div>
                            <div class="flex-1">
                                <div class="mb-2 mt-1">
                                    <span class="text-xs font-bold uppercase tracking-widest text-orange-400 bg-orange-500/10 px-3 py-1 rounded-full">Every month</span>
                                </div>
                                <h3 class="text-xl font-bold text-heading-1 mb-2">Monthly hosting</h3>
                                <p class="text-heading-3 text-sm leading-relaxed">
                                    Keep your portfolio live, secure, and online. Includes <span class="font-medium text-heading-2">minor text changes</span> such as updating your job title or adding a skill. Cancel anytime.
                                </p>
                                <ul class="mt-4 space-y-1.5 text-sm text-heading-3">
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Portfolio stays live and secure</li>
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Minor changes included</li>
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>No contract, cancel anytime</li>
                                </ul>
                            </div>
                            <div class="text-center sm:text-right shrink-0">
                                <div class="text-5xl font-bold text-heading-1">£5</div>
                                <div class="text-sm text-heading-3 mt-1">per month</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="flex flex-col md:flex-row items-stretch gap-0 group">
                    <div class="flex flex-col items-center md:items-start md:w-16 shrink-0">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-red-500 to-amber-500 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-red-500/30 z-10 shrink-0">
                            3
                        </div>
                    </div>

                    <div class="md:ml-6 flex-1">
                        <div class="bg-box-bg border border-box-border rounded-2xl p-6 md:p-8 flex flex-col sm:flex-row sm:items-center gap-6 hover:border-red-500/40 transition-colors duration-300">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-2">
                                    <span class="text-xs font-bold uppercase tracking-widest text-red-400 bg-red-500/10 px-3 py-1 rounded-full">When needed</span>
                                </div>
                                <h3 class="text-xl font-bold text-heading-1 mb-2">Major update</h3>
                                <p class="text-heading-3 text-sm leading-relaxed">
                                    Need a new section, a redesign, or a significant change? That month costs <span class="font-medium text-heading-2">£5 + £5 = £10 total</span>. Only charged in the month you request it.
                                </p>
                                <ul class="mt-4 space-y-1.5 text-sm text-heading-3">
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>New sections or full redesigns</li>
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Only charged when you ask for it</li>
                                    <li class="flex items-center gap-2"><svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Back to £5/month the next month</li>
                                </ul>
                            </div>
                            <div class="text-center sm:text-right shrink-0">
                                <div class="text-4xl font-bold text-heading-1">£10</div>
                                <div class="text-sm text-heading-3 mt-1">that month only</div>
                                <div class="text-xs text-heading-3/70 mt-0.5">(£5 hosting + £5 update)</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Summary row -->
            <div class="mt-12 grid grid-cols-3 gap-4 bg-box-bg/50 border border-box-border rounded-2xl p-6 text-center">
                <div>
                    <div class="text-2xl font-bold text-heading-1">£10</div>
                    <div class="text-xs text-heading-3 mt-1">To get started</div>
                </div>
                <div class="border-x border-box-border">
                    <div class="text-2xl font-bold text-heading-1">£5<span class="text-base font-normal">/mo</span></div>
                    <div class="text-xs text-heading-3 mt-1">To stay live</div>
                </div>
                <div>
                    <div class="text-2xl font-bold text-heading-1">+£10</div>
                    <div class="text-xs text-heading-3 mt-1">For major updates</div>
                </div>
            </div>

        </div>
    </Container>
</section>
