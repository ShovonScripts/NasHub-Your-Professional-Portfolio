---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";

const faqCategories = [
    {
        category: "Getting Started",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`,
        faqs: [
            {
                q: "What exactly do I get for £10?",
                a: "You get a fully built, live personal portfolio website at your own link, like yourname.nashub.uk. Our developer builds it by hand using the information you provide. It includes your photo, bio, skills, work experience, education, links, and projects, all designed professionally and ready to share. Your first month of hosting is included in the £10."
            },
            {
                q: "Do I need any technical skills?",
                a: "None at all. You simply fill in an online form with your details. It takes about 10 minutes. Our developer does everything else. You never need to touch any code, hosting settings, or design tools."
            },
            {
                q: "How long does it take to get my portfolio?",
                a: "Your portfolio will be live within 2–3 working days of submitting your form and completing payment. You will receive an email with your live link as soon as it is ready."
            },
            {
                q: "What information do I need to provide?",
                a: "Just the basics: your name, job title, location, a professional photo, a short bio, your work experience, education, skills, and any links you want to include such as LinkedIn or GitHub. We guide you through everything step by step in the form. If you are missing something, you can leave it out and add it later."
            }
        ]
    },
    {
        category: "About Your Portfolio",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125z" /></svg>`,
        faqs: [
            {
                q: "What will my portfolio look like?",
                a: "Your portfolio will be clean, professional, and mobile-friendly. It will work perfectly on phones, tablets, and desktops. You can choose your preferred style: minimal and clean, bold and colourful, or professional and corporate. We design it to match. Every portfolio is built individually, not generated by a machine."
            },
            {
                q: "Will my portfolio look the same as everyone else's?",
                a: "No. Although we use design templates as a starting point, every portfolio is personalised using your own content, your photo, your colour preferences, and your style choice. No two portfolios look identical."
            },
            {
                q: "Can I see examples before I sign up?",
                a: "Yes. We have live portfolio examples on the website so you can see exactly what we build before you commit to anything."
            },
            {
                q: "Is my portfolio mobile friendly?",
                a: "Yes. Every portfolio we build is fully responsive and tested on mobile, tablet, and desktop screens before going live."
            },
            {
                q: "Will my portfolio appear on Google?",
                a: "Yes. Your portfolio is a live public website, which means it can be found on Google. We build each portfolio with basic SEO in place, so your name, title, and location are all indexed. Over time your portfolio can rank when someone searches your name."
            }
        ]
    },
    {
        category: "Pricing & Payment",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`,
        faqs: [
            {
                q: "Why is it so cheap compared to other services?",
                a: "Because we have kept the model simple. We build portfolios efficiently using a proven process and host them on our own infrastructure at nashub.uk. We are not a large agency with high overheads. We are a focused digital service that wants to make professional portfolios accessible to everyone."
            },
            {
                q: "What does the £5 per month cover?",
                a: "It covers keeping your portfolio live, secure, and online every single day. It also includes minor text changes, for example updating your job title, adding a new skill, or correcting a detail. As long as you pay £5 per month, your portfolio stays live."
            },
            {
                q: "What counts as a minor change versus a major update?",
                a: "A minor change is a small text edit such as updating your contact email, fixing a typo, changing your job title, or adding a skill. A major update is anything that requires significant work, like adding a new section, redesigning a part of the page, or uploading new project work. Minor changes are included in your monthly £5. Major updates are charged at £10 for that month only."
            },
            {
                q: "Are there any hidden fees?",
                a: "No. You pay £10 to get started (includes your first month), then £5 every month to stay live. That is it. If you request a major update, that month costs £15 instead of £5. No contracts, no setup fees, no surprises."
            },
            {
                q: "How do I pay?",
                a: "After submitting your form you will receive a payment link by email within 24 hours. We accept all major debit and credit cards. Monthly billing is handled automatically so you do not need to do anything each month."
            }
        ]
    },
    {
        category: "Managing Your Portfolio",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.107-1.204l-.527-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
        faqs: [
            {
                q: "Can I make changes to my portfolio after it goes live?",
                a: "Yes. You can log in to your Nas Hub account at any time and submit an update request. Tell us what you want to change, and our developer will make the update within 2 working days."
            },
            {
                q: "What if I want to update my photo or add a new job?",
                a: "Just log in and submit an update request with your new information or photo. If it is a straightforward change it is included in your monthly fee. If it involves a significant redesign or new section it is treated as a major update at £10."
            },
            {
                q: "Can I cancel at any time?",
                a: "Yes. You can cancel your subscription at any time with no penalty. Once you cancel, your portfolio will remain live until the end of your current billing period and then be taken offline. Your data is retained for 30 days after cancellation in case you change your mind."
            },
            {
                q: "What happens to my portfolio if I stop paying?",
                a: "Your portfolio will be paused (taken offline) but not deleted. If you return and resume your subscription within 30 days, your portfolio is restored exactly as it was. After 30 days it may be permanently removed."
            },
            {
                q: "Can I have my own custom domain instead of nashub.uk?",
                a: "We currently host all portfolios at yourname.nashub.uk. If you already own a custom domain and want to use it, contact us at hello@nashub.uk and we can discuss this as an additional service."
            }
        ]
    },
    {
        category: "Trust & Credibility",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
        faqs: [
            {
                q: "Who is behind Nas Hub?",
                a: "Nas Hub is a service of Nasir Digital Consultancy Limited, a private limited company registered in England and Wales. We are a legitimate, compliant UK business. You can verify our registration on the Companies House website. Our parent company website is ndc-agency.co.uk."
            },
            {
                q: "Is my personal information safe?",
                a: "Yes. We take data protection seriously and operate in full compliance with UK GDPR. Your information is used only to build your portfolio and manage your account. We never sell or share your data with third parties. You can request deletion of your data at any time by emailing hello@nashub.uk."
            },
            {
                q: "What if I am not happy with my portfolio?",
                a: "If your portfolio does not match what you submitted in the form, we will fix it at no extra charge. Simply contact us within 5 days of receiving your live link and describe what needs to be changed. We want every client to be proud of their portfolio."
            },
            {
                q: "Is this a subscription I will forget about and keep paying for?",
                a: "We send you a reminder email before each monthly billing date. You are always in control. You can cancel from your account at any time in under a minute. We do not make it difficult to leave."
            }
        ]
    }
];
---

<section id="faq" class="relative pt-20 pb-20">
    <Container>
        <div class="text-center max-w-3xl mx-auto mb-16">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-6 shadow-xl shadow-black/5">
                <span class="text-sm font-medium text-heading-2">Got Questions?</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-heading-1">
                Frequently asked <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-500">questions</span>
            </h2>
            <p class="mt-4 text-heading-3 text-lg">
                Everything you need to know before getting started. Can't find an answer? <a href="mailto:hello@nashub.uk" class="text-orange-400 hover:text-orange-300 underline underline-offset-2 transition-colors">Email us</a>.
            </p>
        </div>

        <!-- Category tabs -->
        <div class="flex flex-wrap justify-center gap-3 mb-12" id="faq-tabs">
            {faqCategories.map((cat, i) => (
                <button
                    data-tab={i}
                    class={`faq-tab flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold border transition-all duration-200 ${i === 0 ? 'bg-orange-600 text-white border-orange-600 shadow-lg shadow-orange-500/25' : 'bg-box-bg border-box-border text-heading-3 hover:border-orange-500/50 hover:text-heading-2'}`}
                >
                    <span set:html={cat.icon} />
                    {cat.category}
                </button>
            ))}
        </div>

        <!-- FAQ Panels -->
        {faqCategories.map((cat, i) => (
            <div data-panel={i} class={`faq-panel max-w-3xl mx-auto ${i !== 0 ? 'hidden' : ''}`}>
                <div class="space-y-3">
                    {cat.faqs.map((faq, j) => (
                        <div class="faq-item bg-box-bg border border-box-border rounded-2xl overflow-hidden transition-all duration-300">
                            <button
                                class="faq-question w-full flex items-center justify-between gap-4 px-6 py-5 text-left font-semibold text-heading-2 hover:text-heading-1 transition-colors"
                                aria-expanded="false"
                                id={`faq-btn-${i}-${j}`}
                                aria-controls={`faq-ans-${i}-${j}`}
                            >
                                <span>{faq.q}</span>
                                <span class="faq-icon shrink-0 w-6 h-6 rounded-full bg-orange-500/10 text-orange-400 flex items-center justify-center transition-transform duration-300">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                    </svg>
                                </span>
                            </button>
                            <div
                                id={`faq-ans-${i}-${j}`}
                                class="faq-answer hidden px-6 pb-5 text-heading-3 leading-relaxed"
                            >
                                {faq.a}
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        ))}

        <!-- Still have a question CTA -->
        <div class="mt-16 max-w-2xl mx-auto text-center">
            <div class="bg-gradient-to-r from-orange-500/10 to-orange-500/10 border border-orange-500/20 rounded-3xl p-8">
                <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center text-orange-400 mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-heading-1 mb-2">Still have a question?</h3>
                <p class="text-heading-3 mb-6">Can't find the answer you're looking for? We're happy to help and typically respond within a few hours during working days.</p>
                <div class="flex flex-wrap justify-center gap-3">
                    <a href="mailto:hello@nashub.uk" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-orange-600 hover:bg-orange-500 text-white font-semibold transition-all duration-200 shadow-lg shadow-orange-500/25 hover:-translate-y-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                        </svg>
                        Email Us
                    </a>
                    <a href="https://wa.me/447449728800" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-green-600 hover:bg-green-500 text-white font-semibold transition-all duration-200 shadow-lg shadow-green-500/25 hover:-translate-y-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        WhatsApp Us
                    </a>
                </div>
            </div>
        </div>
    </Container>
</section>

<script>
    // Tab switching
    const tabs = document.querySelectorAll('.faq-tab');
    const panels = document.querySelectorAll('.faq-panel');

    tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
            const idx = tab.getAttribute('data-tab');

            // Update tab styles
            tabs.forEach(t => {
                t.classList.remove('bg-orange-600', 'text-white', 'border-orange-600', 'shadow-lg', 'shadow-orange-500/25');
                t.classList.add('bg-box-bg', 'border-box-border', 'text-heading-3');
            });
            tab.classList.add('bg-orange-600', 'text-white', 'border-orange-600', 'shadow-lg', 'shadow-orange-500/25');
            tab.classList.remove('bg-box-bg', 'border-box-border', 'text-heading-3');

            // Show/hide panels
            panels.forEach(panel => panel.classList.add('hidden'));
            const activePanel = document.querySelector(`[data-panel="${idx}"]`);
            if (activePanel) activePanel.classList.remove('hidden');
        });
    });

    // Accordion behaviour
    document.querySelectorAll('.faq-question').forEach(btn => {
        btn.addEventListener('click', () => {
            const expanded = btn.getAttribute('aria-expanded') === 'true';
            const answer = btn.nextElementSibling as HTMLElement;
            const icon = btn.querySelector('.faq-icon') as HTMLElement;

            // Close all others in same panel
            const panel = btn.closest('.faq-panel');
            if (panel) {
                panel.querySelectorAll('.faq-question').forEach(otherBtn => {
                    if (otherBtn !== btn) {
                        otherBtn.setAttribute('aria-expanded', 'false');
                        const otherAnswer = otherBtn.nextElementSibling as HTMLElement;
                        const otherIcon = otherBtn.querySelector('.faq-icon') as HTMLElement;
                        otherAnswer?.classList.add('hidden');
                        if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
                    }
                });
            }

            // Toggle current
            if (expanded) {
                btn.setAttribute('aria-expanded', 'false');
                answer?.classList.add('hidden');
                if (icon) icon.style.transform = 'rotate(0deg)';
            } else {
                btn.setAttribute('aria-expanded', 'true');
                answer?.classList.remove('hidden');
                if (icon) icon.style.transform = 'rotate(45deg)';
            }
        });
    });
</script>
