---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
---

<section id="previous-work" class="relative pt-20 pb-20">
    <Container>
        <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
            
            <!-- Left: Text content -->
            <div class="w-full lg:w-1/2 flex flex-col">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-box-bg border border-box-border backdrop-blur-md mb-6 shadow-md shadow-box-shadow w-max">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-orange-500">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="text-sm font-semibold text-heading-2">Our Portfolio</span>
                </div>

                <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-6">
                    See what we've <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-red-500">built before</span>
                </h2>
                
                <Paragraph className="text-lg mb-6">
                    Every portfolio we build is hand-crafted, personalised, and designed to make a lasting impression. Browse our collection of live portfolios to see the quality and care we put into every project.
                </Paragraph>

                <Paragraph className="mb-8">
                    From students to seasoned professionals, each portfolio reflects the unique story of its owner. Yours will be just as unique.
                </Paragraph>

                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="https://previous.nashub.uk" target="_blank" rel="noopener noreferrer" class="group w-full sm:w-auto">
                        <button class="w-full sm:w-auto px-8 py-4 rounded-full bg-gradient-to-r from-orange-600 to-red-600 text-white font-bold text-lg transition-all duration-300 shadow-lg shadow-orange-500/25 hover:shadow-xl hover:shadow-orange-500/30 hover:-translate-y-0.5 flex items-center justify-center gap-2">
                            View Previous Work
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                            </svg>
                        </button>
                    </a>
                </div>
            </div>

            <!-- Right: Preview cards mockup -->
            <div class="w-full lg:w-1/2 relative">
                <div class="absolute -inset-4 bg-gradient-to-tr from-orange-500/10 to-red-500/10 dark:from-orange-500/15 dark:to-red-500/15 rounded-[2rem] blur-2xl"></div>
                
                <div class="relative grid grid-cols-2 gap-4">
                    <!-- Card 1 -->
                    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-white/10 rounded-xl shadow-lg overflow-hidden col-span-1 hover:-translate-y-1 transition-transform duration-300">
                        <div class="h-16 bg-gradient-to-r from-orange-400 to-red-400"></div>
                        <div class="p-3">
                            <div class="flex items-center gap-2 mb-2 -mt-5">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-orange-500 to-red-500 border-2 border-white dark:border-gray-900 shrink-0"></div>
                                <div class="pt-4">
                                    <div class="h-2.5 w-16 bg-heading-1/15 rounded"></div>
                                </div>
                            </div>
                            <div class="space-y-1.5 mt-3">
                                <div class="h-2 w-full bg-heading-1/6 rounded-full"></div>
                                <div class="h-2 w-4/5 bg-heading-1/6 rounded-full"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2 -->
                    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-white/10 rounded-xl shadow-lg overflow-hidden col-span-1 translate-y-6 hover:-translate-y-[-20px] transition-transform duration-300">
                        <div class="h-16 bg-gradient-to-r from-red-400 to-amber-400"></div>
                        <div class="p-3">
                            <div class="flex items-center gap-2 mb-2 -mt-5">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-red-500 to-amber-500 border-2 border-white dark:border-gray-900 shrink-0"></div>
                                <div class="pt-4">
                                    <div class="h-2.5 w-14 bg-heading-1/15 rounded"></div>
                                </div>
                            </div>
                            <div class="space-y-1.5 mt-3">
                                <div class="h-2 w-full bg-heading-1/6 rounded-full"></div>
                                <div class="h-2 w-3/5 bg-heading-1/6 rounded-full"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3 -->
                    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-white/10 rounded-xl shadow-lg overflow-hidden col-span-1 hover:-translate-y-1 transition-transform duration-300">
                        <div class="h-16 bg-gradient-to-r from-amber-400 to-orange-500"></div>
                        <div class="p-3">
                            <div class="flex items-center gap-2 mb-2 -mt-5">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 border-2 border-white dark:border-gray-900 shrink-0"></div>
                                <div class="pt-4">
                                    <div class="h-2.5 w-20 bg-heading-1/15 rounded"></div>
                                </div>
                            </div>
                            <div class="space-y-1.5 mt-3">
                                <div class="h-2 w-full bg-heading-1/6 rounded-full"></div>
                                <div class="h-2 w-2/3 bg-heading-1/6 rounded-full"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 4 -->
                    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-white/10 rounded-xl shadow-lg overflow-hidden col-span-1 translate-y-6 hover:-translate-y-[-20px] transition-transform duration-300">
                        <div class="h-16 bg-gradient-to-r from-orange-500 to-red-500"></div>
                        <div class="p-3">
                            <div class="flex items-center gap-2 mb-2 -mt-5">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-orange-500 to-red-500 border-2 border-white dark:border-gray-900 shrink-0"></div>
                                <div class="pt-4">
                                    <div class="h-2.5 w-12 bg-heading-1/15 rounded"></div>
                                </div>
                            </div>
                            <div class="space-y-1.5 mt-3">
                                <div class="h-2 w-full bg-heading-1/6 rounded-full"></div>
                                <div class="h-2 w-4/5 bg-heading-1/6 rounded-full"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>
