---
import "../styles/global.css"
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import WhyChooseUs from '../components/sections/WhyChooseUs.astro';
import PreviousWork from '../components/sections/PreviousWork.astro';
import Pricing from '../components/sections/Pricing.astro';
import WhoItsFor from '../components/sections/WhoItsFor.astro';
import FAQ from '../components/sections/FAQ.astro';
import CTA from '../components/sections/CTA.astro';
---

<Layout title="Nas Hub | Your professional portfolio, live online">
	<main class="flex flex-col gap-y-20 md:gap-y-32 overflow-hidden">
		<Hero/>
		<HowItWorks/>
		<WhyChooseUs/>
		<PreviousWork/>
		<Pricing/>
		<WhoItsFor/>
		<FAQ/>
